# FreeCAD AI Assistant - Environment Variables
# این فایل را به .env کپی کنید و API keyهای خود را وارد کنید

# Claude API (Anthropic) - پیش‌فرض
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API (اختیاری)
OPENAI_API_KEY=sk-your-key-here

# OpenRouter (اختیاری)
OPENROUTER_API_KEY=your-key-here

# DeepSeek API (اختیاری)
DEEPSEEK_API_KEY=your-key-here

# تنظیمات اضافی (اختیاری)
FREECAD_AI_DEFAULT_PROVIDER=anthropic
FREECAD_AI_DEFAULT_MODEL=claude-3-sonnet-20240229
FREECAD_AI_LANGUAGE=fa
